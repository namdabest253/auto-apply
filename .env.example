# Database (PostgreSQL via Docker Compose)
DATABASE_URL=postgresql://autoapply:autoapply@localhost:5432/autoapply

# Redis (for BullMQ job queues - Phase 3+)
REDIS_URL=redis://localhost:6379

# Auth.js secret - generate with: openssl rand -base64 33
AUTH_SECRET=change-me-generate-with-openssl-rand-base64-33

# Google OAuth (optional - leave blank to disable)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth (optional - leave blank to disable)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Auth.js URL
AUTH_URL=http://localhost:3000

# Encryption key for sensitive credential storage (AES-256-GCM)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=
